# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TAVILY_API_KEY: Required for web search grounding.
# Users configure this via the Secrets panel in the AI Studio UI.
TAVILY_API_KEY="MY_TAVILY_API_KEY"

# FOURSQUARE_API_KEY: Required for Foursquare Places API.
# Users configure this via the Secrets panel in the AI Studio UI.
FOURSQUARE_API_KEY="MY_FOURSQUARE_API_KEY"

# NOTION_CLIENT_ID & NOTION_CLIENT_SECRET: Required for Notion OAuth integration.
NOTION_CLIENT_ID="MY_NOTION_CLIENT_ID"
NOTION_CLIENT_SECRET="MY_NOTION_CLIENT_SECRET"

# GITHUB_CLIENT_ID & GITHUB_CLIENT_SECRET: Required for GitHub OAuth integration.
GITHUB_CLIENT_ID="MY_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="MY_GITHUB_CLIENT_SECRET"

# GOOGLE_CLIENT_ID & GOOGLE_CLIENT_SECRET: Required for Google OAuth integration.
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# CANVA_CLIENT_ID & CANVA_CLIENT_SECRET: Required for Canva OAuth integration.
CANVA_CLIENT_ID="MY_CANVA_CLIENT_ID"
CANVA_CLIENT_SECRET="MY_CANVA_CLIENT_SECRET"

# NVIDIA_API_KEY: Required for NVIDIA GLM model.
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"

# DATABASE_URL: Required for Neon Serverless Database.
# Get this from your Neon Console (neon.tech)
DATABASE_URL="postgres://user:password@hostname/dbname?sslmode=require"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
